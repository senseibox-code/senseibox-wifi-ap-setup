[Unit]
Description=Senseibox Wi-Fi AP Mode Onboarding
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=senseibox
Group=senseibox
WorkingDirectory=/opt/senseibox/senseibox-wifi-ap-mode
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/senseibox/senseibox-wifi-ap-mode/.venv/bin/senseibox-wifi-ap-mode --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full

[Install]
WantedBy=multi-user.target
